# Объявление пакета в EDK2
# DEC-файл говорит системе сборки: как называется пакет, какой у него GUID, какая версия формата самого пакета
# Этот файл поключается в .inf чтобы модуль мог ссылаться на типы/протоколы из пакета
[Defines]
  DEC_SPECIFICATION  = 0x00010005                             # Версия спецификации формата DEC-файла, с которой совместим этот файл.
  PACKAGE_NAME       = MySuperPkg                             # Имя пакета
  PACKAGE_GUID       = 6abec441-198c-404d-b928-07a7a27dc2b8   # Уникальный GUID пакета. Нужно чтобы однозначно идентифицировать пакет, особенно в больших проектах
  PACKAGE_VERSION    = 1.0                                    # Версия пакета
